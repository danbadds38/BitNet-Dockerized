# Copy this file to .env and fill in your values.
# docker compose automatically loads .env from the project root.

# -------------------------------------------------------------------
# Hugging Face token — required only for gated or private models.
# Get yours at: https://huggingface.co/settings/tokens
# -------------------------------------------------------------------
HF_TOKEN=

# -------------------------------------------------------------------
# Runtime defaults (all overridable on the make command line too)
# -------------------------------------------------------------------

# Number of CPU threads to use for inference
BITNET_THREADS=4

# Path to the .gguf model file inside the container
MODEL_PATH=models/BitNet-b1.58-2B-4T/ggml-model-i2_s.gguf

# Benchmark parameters
N_TOKEN=128
N_PROMPT=512
