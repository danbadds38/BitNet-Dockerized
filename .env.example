# Copy this file to .env and fill in your values.
# docker compose AND the Makefile both read .env from the project root.
# Command-line overrides (make VAR=x) always take highest precedence.

# ── Hugging Face ─────────────────────────────────────────────────────────────
# Required only for gated or private models.
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=

# ── Model selection ───────────────────────────────────────────────────────────
# HF repo to download. Preset targets (make setup-small, setup-llama, etc.)
# override these automatically — only set here if using `make setup` directly.
#
# Available models:
#   microsoft/BitNet-b1.58-2B-4T-gguf       2.4B  ← default
#   1bitLLM/bitnet_b1_58-large              0.7B
#   1bitLLM/bitnet_b1_58-3B                 3.3B
#   HF1BitLLM/Llama3-8B-1.58-100B-tokens   8.0B
#   tiiuae/Falcon3-1B-Instruct-1.58bit      1B
#   tiiuae/Falcon3-3B-Instruct-1.58bit      3B
#   tiiuae/Falcon3-7B-Instruct-1.58bit      7B
#   tiiuae/Falcon3-10B-Instruct-1.58bit     10B
MODEL=microsoft/BitNet-b1.58-2B-4T-gguf
MODEL_DIR=models/BitNet-b1.58-2B-4T
QUANT_TYPE=i2_s

# ── Inference settings ────────────────────────────────────────────────────────
# Number of CPU threads (set to your physical core count for best performance)
THREADS=4

# Context window size in tokens (max 4096 for the 2B model)
#CTX_SIZE=16384
CTX_SIZE=2048

# Maximum tokens to generate per response
#N_TOKEN=1024
N_TOKEN=128

# Sampling temperature (higher = more creative, lower = more deterministic)
TEMPERATURE=0.8

# ── Benchmark settings ────────────────────────────────────────────────────────
N_PROMPT=512
